{
  "buildCommand": "echo 'No frontend build needed, serving static files.'",
  "installCommand": "npm install",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "functions": {
    "api/*.js": {
      "runtime": "@vercel/node"
    }
  },
  "devCommand": "npm run dev"
}