{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.2",
      "memory": 512,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.php" },
    {
      "source": "/((?!api/).*)",
      "destination": "/$1"
    }
  ],
  "devCommand": "npm run dev"
}